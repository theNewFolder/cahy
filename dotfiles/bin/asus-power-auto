#!/usr/bin/env bash
# Auto power profile switcher for ASUS TUF laptops
# Switches profiles based on AC/battery state
# Run via udev rule or systemd path unit

set -euo pipefail

AC_ONLINE=$(cat /sys/class/power_supply/ACS0/online 2>/dev/null || cat /sys/class/power_supply/AC0/online 2>/dev/null || echo "1")

if [[ "$AC_ONLINE" == "1" ]]; then
    # On AC power — use Balanced (or Performance if gaming)
    CURRENT=$(asusctl profile get 2>/dev/null | grep -oP 'Active profile: \K\w+')
    if [[ "$CURRENT" != "Balanced" && "$CURRENT" != "Performance" ]]; then
        asusctl profile set Balanced
        notify-send "ASUS Profile" "AC connected — Balanced mode" -i battery-full-charging
    fi
else
    # On battery — switch to Quiet for power saving
    asusctl profile set Quiet
    notify-send "ASUS Profile" "Battery — Quiet mode (power saving)" -i battery-low
fi
