#!/usr/bin/env bash
# GPU stats for waybar (nvidia-smi wrapper)
# Handles RTD3 power-off state gracefully

if ! command -v nvidia-smi &>/dev/null; then
    echo '{"text": "N/A", "tooltip": "nvidia-smi not found"}'
    exit 0
fi

# Check if GPU is powered on
GPU_STATE=$(cat /sys/bus/pci/devices/0000:01:00.0/power/runtime_status 2>/dev/null || echo "unknown")

if [[ "$GPU_STATE" == "suspended" ]]; then
    echo '{"text": "󰍹 OFF", "tooltip": "GPU suspended (RTD3)", "class": "suspended"}'
    exit 0
fi

# Query GPU stats
STATS=$(nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used,memory.total,power.draw --format=csv,noheader,nounits 2>/dev/null)

if [[ -z "$STATS" ]]; then
    echo '{"text": "󰍹 N/A", "tooltip": "GPU query failed"}'
    exit 0
fi

IFS=',' read -r UTIL TEMP MEM_USED MEM_TOTAL POWER <<< "$STATS"
UTIL=$(echo "$UTIL" | tr -d ' ')
TEMP=$(echo "$TEMP" | tr -d ' ')
MEM_USED=$(echo "$MEM_USED" | tr -d ' ')
MEM_TOTAL=$(echo "$MEM_TOTAL" | tr -d ' ')
POWER=$(echo "$POWER" | tr -d ' ')

echo "{\"text\": \"󰍹 ${UTIL}%\", \"tooltip\": \"GPU: ${UTIL}% | ${TEMP}°C\\nVRAM: ${MEM_USED}/${MEM_TOTAL} MiB\\nPower: ${POWER}W\", \"class\": \"active\"}"
