#!/usr/bin/env bash
# Toggle CPU boost on/off for ASUS TUF laptops
# Disabling boost reduces heat/noise significantly on Zen4 chips

BOOST_FILE="/sys/devices/system/cpu/cpufreq/boost"

if [[ ! -f "$BOOST_FILE" ]]; then
    notify-send "CPU Boost" "Boost control not available" -u critical
    exit 1
fi

CURRENT=$(cat "$BOOST_FILE")

if [[ "$CURRENT" == "1" ]]; then
    echo 0 | sudo tee "$BOOST_FILE" > /dev/null
    notify-send "CPU Boost" "Disabled — cooler & quieter" -i dialog-information
else
    echo 1 | sudo tee "$BOOST_FILE" > /dev/null
    notify-send "CPU Boost" "Enabled — full performance" -i dialog-information
fi
