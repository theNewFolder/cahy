#!/bin/sh
# catppuccin-wallpapers-setup — Download Catppuccin wallpapers
# Run once to populate ~/Pictures/Wallpapers/catppuccin/

DIR="$HOME/Pictures/Wallpapers/catppuccin"
mkdir -p "$DIR"

if [ "$(ls -A "$DIR" 2>/dev/null)" ]; then
    COUNT=$(ls "$DIR" | wc -l)
    echo "Wallpapers already present: $COUNT files in $DIR"
    exit 0
fi

echo "Downloading Catppuccin wallpapers..."
TMPDIR=$(mktemp -d)
git clone --depth 1 https://github.com/catppuccin/wallpapers.git "$TMPDIR/walls" 2>/dev/null

if [ ! -d "$TMPDIR/walls" ]; then
    echo "Failed to clone wallpapers repo"
    rm -rf "$TMPDIR"
    exit 1
fi

# Copy all wallpapers (png, jpg, webp)
find "$TMPDIR/walls" -maxdepth 2 -type f \( -name "*.png" -o -name "*.jpg" -o -name "*.jpeg" -o -name "*.webp" \) | while read -r f; do
    cp "$f" "$DIR/"
done

# Create a symlink for the default wallpaper (first one found)
DEFAULT=$(ls "$DIR"/*.png 2>/dev/null | head -1)
[ -n "$DEFAULT" ] && ln -sf "$(basename "$DEFAULT")" "$DIR/cat-mocha-default.png"

rm -rf "$TMPDIR"
COUNT=$(ls "$DIR" | wc -l)
echo "Downloaded $COUNT wallpapers to $DIR"
echo "Default: $(readlink "$DIR/cat-mocha-default.png" 2>/dev/null || echo 'none')"
echo "Wallpaper rotation and hyprpaper will use these automatically."
