#!/bin/sh
# git-waybar-status — Show current git branch + status for Waybar
# Returns JSON for waybar custom module

# Try to get info from focused window's working directory via Emacs
DIR=$(emacsclient --eval '(with-current-buffer (window-buffer) default-directory)' 2>/dev/null | tr -d '"')

# Fallback to home dir
[ -z "$DIR" ] && DIR="$HOME"

cd "$DIR" 2>/dev/null || cd "$HOME"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    BRANCH=$(git branch --show-current 2>/dev/null)
    DIRTY=$(git status --porcelain 2>/dev/null | wc -l)
    AHEAD=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo 0)

    if [ "$DIRTY" -gt 0 ]; then
        ICON="󰊢"
        CLASS="dirty"
    elif [ "$AHEAD" -gt 0 ]; then
        ICON="󰜘"
        CLASS="ahead"
    else
        ICON="󰊤"
        CLASS="clean"
    fi

    TEXT="$ICON $BRANCH"
    [ "$DIRTY" -gt 0 ] && TEXT="$TEXT ±$DIRTY"
    [ "$AHEAD" -gt 0 ] && TEXT="$TEXT ↑$AHEAD"

    printf '{"text": "%s", "tooltip": "%s — %s changed, %s ahead", "class": "%s"}\n' \
        "$TEXT" "$BRANCH" "$DIRTY" "$AHEAD" "$CLASS"
else
    printf '{"text": "", "tooltip": "Not a git repo", "class": "no-git"}\n'
fi
