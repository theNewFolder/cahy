# Mako notification daemon — Catppuccin Mocha theme
anchor=top-right
font=DankMono Nerd Font 11
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
border-radius=8
border-size=2
default-timeout=5000
height=150
icons=true
layer=overlay
margin=10
max-icon-size=48
max-visible=3
padding=12
width=350

[urgency=critical]
border-color=#f38ba8
default-timeout=0

[urgency=low]
border-color=#585b70
default-timeout=3000
