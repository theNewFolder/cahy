# snapper config for root subvolume (@)
# Place at /etc/snapper/configs/root after install
# Setup: sudo snapper -c root create-config /

SUBVOLUME="/"
FSTYPE="btrfs"

# Auto-snapshot on timeline
TIMELINE_CREATE="yes"
TIMELINE_CLEANUP="yes"

# Keep: 5 hourly, 7 daily, 4 weekly, 0 monthly, 0 yearly
TIMELINE_LIMIT_HOURLY="5"
TIMELINE_LIMIT_DAILY="7"
TIMELINE_LIMIT_WEEKLY="4"
TIMELINE_LIMIT_MONTHLY="0"
TIMELINE_LIMIT_YEARLY="0"

# Number-based cleanup (keep last 5)
NUMBER_CLEANUP="yes"
NUMBER_MIN_AGE="1800"
NUMBER_LIMIT="5"
NUMBER_LIMIT_IMPORTANT="5"

# Allow user 'dev' to manage snapshots
ALLOW_USERS="dev"
ALLOW_GROUPS=""
